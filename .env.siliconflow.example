LLM_PROVIDER=api
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=<your-siliconflow-api-key>
LLM_REASONING_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_FAST_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_ENABLE_THINKING=false
SKIP_VLLM=1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1
LLM_CLASSIFY_TIMEOUT_SECONDS=25
LLM_CLASSIFY_MAX_RETRIES=0
LLM_CLASSIFY_FALLBACK_ENABLED=true
ANALYST_DRAFT_MAX_ATTEMPTS=1
ANALYST_DRAFT_MAX_TOKENS=1400
