# =============================================================
# Financial Filings Analysis Agent — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================

# ---------- LLM endpoint ----------
# local: start/reuse local vLLM through scripts/start_full_stack.sh
# api: skip local vLLM and call an OpenAI-compatible hosted API
# You can also switch with LLM_PROFILE=local or LLM_PROFILE=siliconflow.
LLM_PROVIDER=local

# ---------- Local LLM (vLLM OpenAI-compatible API) ----------
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_REASONING_MODEL=Qwen/Qwen3-8B-AWQ
LLM_FAST_MODEL=Qwen/Qwen3-8B-AWQ

# ---------- SiliconFlow API mode ----------
# Uncomment these lines to use SiliconFlow instead of local vLLM.
# Keep your real API key in .env only; do not commit it.
# LLM_PROVIDER=api
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-...
# LLM_REASONING_MODEL=deepseek-ai/DeepSeek-V4-Flash
# LLM_FAST_MODEL=deepseek-ai/DeepSeek-V4-Flash
# LLM_ENABLE_THINKING=false
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=1
# LLM_CLASSIFY_TIMEOUT_SECONDS=25
# LLM_CLASSIFY_MAX_RETRIES=0
# LLM_CLASSIFY_FALLBACK_ENABLED=true
# ANALYST_DRAFT_MAX_ATTEMPTS=1
# ANALYST_DRAFT_MAX_TOKENS=1400
# ANALYST_DRAFT_ENABLED=true
# SKIP_VLLM=1

# ---------- Embedding (sentence-transformers, in-process) ----------
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
# GPU recommended for build_vectorstore; use cpu if vLLM is using most VRAM
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=256

# ---------- SEC EDGAR ----------
# Prefer explicit name + email (required by sec_edgar_downloader):
SEC_EDGAR_COMPANY_NAME=YourName
SEC_EDGAR_EMAIL=your-email@example.com
# Or legacy single line (parsed as "Name email@domain"):
# SEC_EDGAR_USER_AGENT=YourName your-email@example.com

# ---------- Data pipeline ----------
# DATA_YEARS=3

# ---------- RAG rollout / retrieval ----------
# RAG_INDEX_VERSION=v1          # v1 or v2
# RAG_COLLECTION_V1=filing_chunks
# RAG_COLLECTION_V2=filing_chunks_v2
# RAG_MIXED_FALLBACK=true       # true: allow MIXED/UNKNOWN only as fallback
# RAG_MMR_LAMBDA=0.75           # light MMR rerank weight
# RAG_OVERFETCH_MULTIPLIER=8    # over-fetch before rerank

# ---------- Paths (defaults work out of the box) ----------
# DATA_DIR=./data
# DUCKDB_PATH=./data/db/financial.duckdb
# CHROMA_DIR=./data/vectorstore

# ---------- FastAPI ----------
# API_HOST=0.0.0.0
# API_PORT=8080
